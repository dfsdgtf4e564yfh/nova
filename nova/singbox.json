<!doctype html>
<html lang="fa" dir="rtl" data-theme="dark">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>Nova Proxy configs</title>
<meta name="nova-userhub-version" content="4.0.0" />
<link rel="icon" type="image/svg+xml" href="/logo-mark.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Vazirmatn:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<script>
  (function(){ try{
    var l = localStorage.getItem('nova-user-lang') || 'fa';
    document.documentElement.lang = l; document.documentElement.dir = l==='fa'?'rtl':'ltr';
    var th = localStorage.getItem('nova-theme'); document.documentElement.dataset.theme = th==='light'?'light':'dark';
  }catch(e){} })();
</script>
<style>
  :root{
    --bg:#070809; --panel:#0c0e12; --card:#101319; --card2:#0b0d11;
    --bd:#1c2027; --bd2:#262b34; --tx:#e9edf4; --tx2:#aeb6c4; --mu:#6f7888;
    --ac:#22d3ee; --ac2:#a855f7; --ok:#34d399; --wn:#f5b042; --dg:#f87171;
    --grad:linear-gradient(120deg,#22d3ee,#7c5cff);
    --radius:12px; --r-sm:9px; --r-lg:16px;
    --ac-soft:color-mix(in srgb,var(--ac) 14%,transparent);
    --ac-line:color-mix(in srgb,var(--ac) 38%,transparent);
  }
  html[data-theme=light]{
    --bg:#f4f6fb; --panel:#ffffff; --card:#ffffff; --card2:#f7f9fc;
    --bd:#e6eaf1; --bd2:#dde2eb; --tx:#101622; --tx2:#3a465c; --mu:#5f6a7d;
    --ac:#0ea5c4; --ac2:#7c3aed; --grad:linear-gradient(120deg,#0891b2,#7c3aed); --ok:#047857; --wn:#b45309; --dg:#dc2626;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{background:var(--bg);color:var(--tx);min-height:100vh;font-size:14px;font-family:'Inter','Vazirmatn',system-ui,-apple-system,Segoe UI,Tahoma,sans-serif;-webkit-font-smoothing:antialiased}
  html[dir=rtl] body{font-family:'Vazirmatn','Inter',system-ui,Tahoma,sans-serif}
  .wrap{max-width:980px;margin:0 auto;padding:24px 18px 64px}
  .topbar{display:flex;align-items:center;gap:14px;margin-bottom:6px}
  .brand{display:flex;align-items:center;gap:11px}
  .brand .mark{width:42px;height:42px;flex:0 0 42px;display:flex;align-items:center;justify-content:center;background:var(--card2);border:1px solid var(--bd);border-radius:11px;overflow:hidden}
  .brand .mark img{width:31px;height:31px;object-fit:contain;display:block}
  .brand .name{font-size:17px;font-weight:800;color:var(--tx);letter-spacing:.2px}
  .brand .env{display:flex;align-items:center;gap:6px;font-size:10.5px;color:var(--mu);font-weight:600;margin-top:2px}
  .brand .env .d{width:6px;height:6px;border-radius:50%;background:var(--ok);box-shadow:0 0 0 3px color-mix(in srgb,var(--ok) 22%,transparent)}
  .controls{margin-inline-start:auto;display:flex;gap:8px}
  .segmented{display:flex;border:1px solid var(--bd);background:var(--card);border-radius:var(--r-sm);padding:3px;height:36px}
  .segmented button{border:none;background:transparent;color:var(--mu);font:inherit;font-size:12px;font-weight:700;padding:0 11px;border-radius:6px;transition:.12s;cursor:pointer;line-height:1}
  .segmented button.on{background:var(--ac);color:#04121a}
  html[data-theme=light] .segmented button.on{color:#fff}
  .subtitle{color:var(--tx2);font-size:13.5px;line-height:1.75;margin:4px 0 18px}
  .subtitle b{color:var(--ac);font-weight:700}
  .freebar{display:flex;align-items:center;justify-content:center;gap:8px;background:var(--ac-soft);border:1px solid var(--ac-line);color:var(--ac);font-weight:700;font-size:13px;line-height:1.5;border-radius:var(--radius);padding:11px 14px;margin:0 0 18px;text-align:center}
  .usage{background:var(--card);border:1px solid var(--bd);border-radius:var(--radius);padding:15px 16px;margin-bottom:16px}
  .usage[hidden]{display:none}
  .usage-top{display:flex;gap:22px;flex-wrap:wrap;align-items:flex-end;margin-bottom:11px}
  .ustat{display:flex;flex-direction:column;gap:3px}
  .ustat .lbl{font-size:10px;font-weight:700;letter-spacing:.7px;text-transform:uppercase;color:var(--mu)}
  .ustat .val{font-size:16px;font-weight:700;color:var(--tx);line-height:1}
  .ustat .val.warn{color:var(--wn)} .ustat .val.dg{color:var(--dg)}
  .bar{height:8px;border-radius:999px;background:var(--card2);border:1px solid var(--bd);overflow:hidden}
  .bar-fill{height:100%;border-radius:999px;background:var(--grad);width:0;transition:width .45s ease}
  .bar-fill.warn{background:var(--wn)} .bar-fill.dg{background:var(--dg)}
  .usplit{margin-top:9px;font-size:12px;color:var(--tx2);display:flex;gap:16px;flex-wrap:wrap}
  .usplit .ar{color:var(--ac);font-weight:700}
  .sublink{display:flex;align-items:center;gap:10px;background:var(--card);border:1px solid var(--bd);border-radius:var(--radius);padding:11px 14px;margin-bottom:22px}
  .sublink code{flex:1;min-width:0;font-family:ui-monospace,'SF Mono',monospace;font-size:11.5px;color:var(--tx2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;direction:ltr;text-align:left}
  .appgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(232px,1fr));gap:12px}
  .appcard{border:1px solid var(--bd);border-radius:12px;padding:14px;background:var(--card2);display:flex;flex-direction:column;gap:13px}
  .appcard.rec{border-color:var(--ac-line)}
  .appcard-h{display:flex;align-items:center;gap:10px}
  .appcard-h .ic{width:32px;height:32px;flex:0 0 32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;color:#fff}
  .appcard-h .nm{font-size:14px;font-weight:700;color:var(--tx)}
  .appcard-h .rec-badge{margin-inline-start:auto;display:inline-flex;align-items:center;gap:4px;font-size:10.5px;font-weight:700;color:var(--ac);background:var(--ac-soft);border:1px solid var(--ac-line);border-radius:999px;padding:2px 8px}
  .appcard-qr{display:flex;justify-content:center}
  .appcard-qr .qbox{background:#fff;border-radius:10px;padding:9px;width:140px;height:140px;display:flex;align-items:center;justify-content:center}
  .appcard-qr canvas,.appcard-qr img{display:block;width:122px;height:122px}
  .qmiss{font-size:11px;color:#555;text-align:center}
  .scanhint{font-size:11px;color:var(--mu);text-align:center;margin-top:-4px}
  .appcard-acts{display:flex;flex-direction:column;gap:7px}
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;height:38px;padding:0 14px;border-radius:var(--r-sm);font:inherit;font-size:13px;font-weight:600;border:1px solid transparent;transition:.13s;cursor:pointer;text-decoration:none}
  .btn.primary{background:var(--ac);color:#04121a;border-color:var(--ac);width:100%}
  html[data-theme=light] .btn.primary{color:#fff}
  .btn.primary:hover{filter:brightness(1.07)}
  .btn.ghost{background:var(--card);color:var(--tx);border-color:var(--bd2)}
  .btn.ghost:hover{border-color:var(--ac);color:var(--ac)}
  .btn.sm{height:32px;padding:0 12px;font-size:12px}
  .foot{margin-top:30px;text-align:center;color:var(--mu);font-size:12px}
  .foot .fsocial{display:flex;justify-content:center;gap:12px;margin-top:10px}
  .foot .fsocial a{display:flex;align-items:center;justify-content:center;width:34px;height:34px;border:1px solid var(--bd);border-radius:9px;color:var(--mu);transition:.12s}
  .foot .fsocial a:hover{border-color:var(--bd2);transform:translateY(-1px)}
  .foot .fsocial svg{width:18px;height:18px}
  .foot .fsocial a .tg{color:#229ED9}.foot .fsocial a .ig{color:#E1306C}
  .toast{position:fixed;inset-inline:0;bottom:22px;margin:auto;width:max-content;max-width:90%;background:var(--ac);color:#04121a;font-weight:700;padding:9px 18px;border-radius:999px;font-size:13px;opacity:0;transform:translateY(8px);transition:.2s;pointer-events:none;z-index:20}
  html[data-theme=light] .toast{color:#fff}
  .toast.show{opacity:1;transform:none}
  @media(max-width:520px){.topbar{flex-wrap:wrap}.controls{margin-inline-start:0;width:100%}}
  /* Phone polish (additive, mobile-only): comfortable tap targets, tighter gutters, no sideways scroll */
  @media(max-width:480px){
    .wrap{padding:16px 14px 48px}
    .appgrid{grid-template-columns:1fr;gap:10px}
    .appcard-qr .qbox{width:132px;height:132px;padding:8px}
    .appcard-qr canvas,.appcard-qr img{width:116px;height:116px}
    .segmented{height:40px}.segmented button{padding:0 13px;font-size:12.5px}
    .btn{height:44px}.btn.sm{height:38px}
    .rpchip{padding:8px 14px}
    .usage-top{gap:16px}
    .radar-cfg{font-size:10.5px}
  }
  .radar{background:var(--card);border:1px solid var(--ac-line);border-radius:var(--radius);padding:14px 16px;margin-bottom:22px}
  .radar-h{display:flex;align-items:center;gap:11px}
  .radar-ic{width:34px;height:34px;flex:0 0 34px;display:flex;align-items:center;justify-content:center;background:var(--ac-soft);border:1px solid var(--ac-line);border-radius:9px;font-size:16px}
  .radar-tt{min-width:0}
  .radar-title{font-size:14px;font-weight:800;color:var(--tx)}
  .radar-sub{font-size:11.5px;color:var(--mu);margin-top:2px;line-height:1.5}
  .radar-run{width:100%;margin-top:12px}
  .radar-ports{display:flex;flex-wrap:wrap;gap:7px;margin-top:12px}
  .rpchip{background:var(--card2);border:1px solid var(--bd);border-radius:999px;color:var(--tx2);padding:6px 13px;font-size:12.5px;font-weight:700;font-family:inherit;cursor:pointer;transition:.12s}
  .rpchip.on{background:var(--ac);border-color:var(--ac);color:#04121a;font-weight:800}
  html[data-theme=light] .rpchip.on{color:#fff}
  .radar-bar{margin-top:12px}
  .radar-msg{font-size:12px;color:var(--tx2);margin-top:8px;min-height:16px;text-align:center}
  .radar-results{margin-top:6px}
  .radar-results table{width:100%;border-collapse:collapse;font-size:12px}
  .radar-results th,.radar-results td{padding:6px 6px;text-align:center;border-bottom:1px solid var(--bd)}
  .radar-results th{color:var(--mu);font-weight:600;font-size:10.5px}
  .radar-results td code{font-family:ui-monospace,'SF Mono',monospace;direction:ltr;color:var(--ac)}
  .radar-results tr.best td{background:var(--ac-soft)}
  .radar-out{margin-top:12px}
  .radar-cfg{background:var(--card2);border:1px solid var(--bd);border-radius:9px;padding:10px;font-family:ui-monospace,monospace;font-size:10px;direction:ltr;text-align:left;word-break:break-all;color:var(--tx2);max-height:88px;overflow:auto;margin-bottom:8px}
  .radar-qr{display:flex;justify-content:center;margin-top:12px}
  .radar-qr .qbox{background:#fff;border-radius:10px;padding:9px;line-height:0}
  /* Status + identity card (merged in so the subscription page still shows account state) */
  .status{background:var(--card);border:1px solid var(--bd);border-radius:var(--radius);padding:16px 17px;margin-bottom:16px;position:relative;overflow:hidden}
  .status[hidden]{display:none}
  .status::before{content:'';position:absolute;top:0;inset-inline:0;height:3px;background:var(--grad)}
  .status.disabled::before,.status.paused::before{background:var(--dg)}
  .status.expired::before,.status.quota-exceeded::before,.status.daily-quota-exceeded::before{background:var(--wn)}
  .status-row{display:flex;align-items:center;gap:12px;justify-content:space-between;flex-wrap:wrap}
  .badge{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:999px;font-size:12px;font-weight:700;letter-spacing:.2px}
  .badge .d2{width:7px;height:7px;border-radius:50%;flex:0 0 7px}
  .badge.active{background:color-mix(in srgb,var(--ok) 14%,transparent);color:var(--ok);border:1px solid color-mix(in srgb,var(--ok) 38%,transparent)} .badge.active .d2{background:var(--ok);box-shadow:0 0 6px var(--ok)}
  .badge.disabled,.badge.paused{background:color-mix(in srgb,var(--dg) 14%,transparent);color:var(--dg);border:1px solid color-mix(in srgb,var(--dg) 38%,transparent)} .badge.disabled .d2,.badge.paused .d2{background:var(--dg)}
  .badge.expired,.badge.quota-exceeded,.badge.daily-quota-exceeded{background:color-mix(in srgb,var(--wn) 14%,transparent);color:var(--wn);border:1px solid color-mix(in srgb,var(--wn) 38%,transparent)} .badge.expired .d2,.badge.quota-exceeded .d2,.badge.daily-quota-exceeded .d2{background:var(--wn)}
  .uname{font-size:20px;font-weight:800;color:var(--tx);margin-top:12px;line-height:1.2;word-break:break-word}
  .utoken{display:inline-flex;align-items:center;gap:7px;font-family:ui-monospace,'SF Mono',monospace;font-size:11.5px;color:var(--mu);direction:ltr;margin-top:5px;word-break:break-all;cursor:pointer;transition:.12s}
  .utoken:hover{color:var(--ac)}
  .utoken svg{width:13px;height:13px;flex:0 0 13px;opacity:.7}
</style>
</head>
<body>
  <div class="wrap">
    <header class="topbar">
      <div class="brand">
        <div class="mark"><img src="/logo-mark.svg" alt="Nova Proxy" /></div>
        <div>
          <div class="name" role="heading" aria-level="1">Nova Proxy</div>
          <div class="env"><span class="d"></span><span id="brandsub">configs</span></div>
        </div>
      </div>
      <div class="controls">
        <div class="segmented" id="lang"><button data-l="en">EN</button><button data-l="fa">فا</button><button data-l="ru">РУ</button></div>
        <div class="segmented" id="theme"><button data-t="light">☀</button><button data-t="dark">☾</button></div>
      </div>
    </header>

    <p class="subtitle" id="subtitle"></p>

    <div class="freebar" id="freebar"></div>

    <section class="status" id="statuscard" hidden>
      <div class="status-row">
        <span class="badge" id="statusbadge"><span class="d2"></span><span id="statustext">-</span></span>
      </div>
      <div class="uname" id="uname"></div>
      <div class="utoken" id="utoken" role="button" tabindex="0" title=""><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg><span id="utoken-txt"></span></div>
    </section>

    <section class="usage" id="usage" hidden>
      <div class="usage-top">
        <div class="ustat"><span class="lbl" id="ul-used">Used</span><span class="val" id="u-used">-</span></div>
        <div class="ustat"><span class="lbl" id="ul-total">Total</span><span class="val" id="u-total">-</span></div>
        <div class="ustat"><span class="lbl" id="ul-exp">Expires</span><span class="val" id="u-exp">-</span></div>
      </div>
      <div class="bar" id="u-bar-wrap"><div class="bar-fill" id="u-bar"></div></div>
      <div class="usplit" id="u-split"></div>
    </section>

    <div class="sublink">
      <button class="btn ghost sm" id="copyraw"></button>
      <code id="rawsub">…</code>
    </div>

    <section class="radar" id="radar">
      <div class="radar-h">
        <span class="radar-ic">📡</span>
        <div class="radar-tt"><div class="radar-title" id="radar-title"></div><div class="radar-sub" id="radar-sub"></div></div>
      </div>
      <div class="radar-ports" id="radar-ports" role="group"><button type="button" class="rpchip on" data-port="443" aria-pressed="true">443</button><button type="button" class="rpchip" data-port="8443" aria-pressed="false">8443</button><button type="button" class="rpchip" data-port="2053" aria-pressed="false">2053</button><button type="button" class="rpchip" data-port="2083" aria-pressed="false">2083</button><button type="button" class="rpchip" data-port="2087" aria-pressed="false">2087</button><button type="button" class="rpchip" data-port="2096" aria-pressed="false">2096</button></div>
      <button class="btn primary radar-run" id="radar-run"></button>
      <div class="bar radar-bar" id="radar-bar" style="display:none"><div class="bar-fill" id="radar-fill"></div></div>
      <div class="radar-msg" id="radar-msg" role="status" aria-live="polite"></div>
      <div id="radar-results" class="radar-results"></div>
      <div id="radar-apply-row" style="display:none;margin-top:12px">
        <button class="btn primary" id="radar-apply" style="width:100%"></button>
        <div class="radar-msg" id="radar-apply-msg" role="status" aria-live="polite" style="margin-top:6px"></div>
      </div>
      <div id="radar-out" class="radar-out" style="display:none">
        <div class="radar-cfg" id="radar-cfg"></div>
        <button class="btn primary sm" id="radar-copy" style="width:100%"></button>
        <div class="radar-qr" id="radar-qr"></div>
      </div>
    </section>

    <div class="appgrid" id="grid"></div>

    <footer class="foot" id="foot"></footer>
  </div>
  <div class="toast" id="toast" role="status" aria-live="polite" aria-atomic="true"></div>

  <script src="/qrcode.min.js"></script>
  <script>
  (function(){
    var I18N = {
